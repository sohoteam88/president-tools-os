# ============================================================
# Herbalife Team Tool — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Supabase (Database + Auth)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct DB connection (for Drizzle migrations — NOT for runtime queries)
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Supabase DB for Drizzle (Transaction Pooler for serverless)
# Get from: Supabase Dashboard → Settings → Database → Connection string → Transaction
DATABASE_URL_POOLED=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ------------------------------------------------------------
# App Configuration
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
ADMIN_EMAIL=stevensc082@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=stevensc082@gmail.com

# Secret for signing invite tokens (generate with: openssl rand -base64 32)
INVITE_TOKEN_SECRET=REPLACE_WITH_RANDOM_SECRET_32_CHARS_MIN

# ------------------------------------------------------------
# Cloudflare R2 (Storage)
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# ------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=herbalife-team-tool
CLOUDFLARE_R2_PUBLIC_URL=https://YOUR_BUCKET.r2.dev

# ------------------------------------------------------------
# AI — Anthropic (Claude)
# Get from: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ------------------------------------------------------------
# AI — OpenAI (Whisper transcription + GPT-4o Vision)
# Get from: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# ------------------------------------------------------------
# Email (Resend)
# Get from: https://resend.com/api-keys
# ------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=team@yourteam.com

# ------------------------------------------------------------
# Video CDN (Bunny.net Stream)
# Get from: https://dash.bunny.net/stream
# ------------------------------------------------------------
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=

# ------------------------------------------------------------
# Background Jobs (Upstash Redis / BullMQ)
# Get from: https://upstash.com/
# ------------------------------------------------------------
REDIS_URL=redis://default:PASSWORD@YOUR_ENDPOINT.upstash.io:6379
REDIS_TOKEN=
CRON_SECRET=

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://PUBLIC_KEY@SENTRY_HOST/PROJECT_ID
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
